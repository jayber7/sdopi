{"type":"before","callId":"call@28","startTime":70719.86,"class":"Frame","method":"evaluateExpression","params":{"expression":"async args => {\n        const {\n          proyectoId,\n          rubroData\n        } = args;\n        const catRubros = await (await fetch(`/api/catalogo/rubros?jefatura=DI`, {\n          credentials: 'include'\n        })).json();\n        const payload = [];\n        for (const rd of rubroData) {\n          const catRubro = catRubros.find(cr => cr.nombre === rd.nombre);\n          if (!catRubro) continue;\n          const catItems = await (await fetch(`/api/catalogo/rubros/${catRubro.id}/items`, {\n            credentials: 'include'\n          })).json();\n          const itemNumeros = new Set(rd.items.map(i => i.numero));\n          const matchingItems = catItems.filter(ci => itemNumeros.has(ci.numero));\n          if (matchingItems.length === 0) continue;\n          payload.push({\n            rubroCatalogoId: catRubro.id,\n            itemCatalogoIds: matchingItems.map(ci => ci.id)\n          });\n        }\n        await fetch(`/api/proyectos/${proyectoId}/importar-items`, {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify({\n            rubros: payload\n          }),\n          credentials: 'include'\n        });\n      }","isFunction":true,"arg":{"value":{"o":[{"k":"proyectoId","v":{"n":11}},{"k":"rubroData","v":{"a":[{"o":[{"k":"codigo","v":{"s":"M01"}},{"k":"nombre","v":{"s":"MOVIMIENTO DE TIERRAS"}},{"k":"items","v":{"a":[{"o":[{"k":"numero","v":{"n":1}},{"k":"descripcion","v":{"s":"INSTALACION DE FAENAS"}},{"k":"unidad","v":{"s":"GLB"}},{"k":"precioUnitario","v":{"n":47860.38}},{"k":"cantidadContrato","v":{"n":0.5}}],"id":5},{"o":[{"k":"numero","v":{"n":2}},{"k":"descripcion","v":{"s":"LIMPIEZA, DESBOSQUE Y DESTRONQUE (CHACO)"}},{"k":"unidad","v":{"s":"HA."}},{"k":"precioUnitario","v":{"n":4767.61}},{"k":"cantidadContrato","v":{"n":5.